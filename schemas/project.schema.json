{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project",
  "type": "object",
  "required": [
    "project_id",
    "title",
    "output_text_license",
    "code_license",
    "model_backend",
    "default_model_profile",
    "local_model_profiles",
    "allowed_sources",
    "style_profiles",
    "divine_name_policy",
    "review_policy",
    "release_channel",
    "source_manifests"
  ],
  "additionalProperties": false,
  "properties": {
    "project_id": { "type": "string", "pattern": "^proj\\.[a-z0-9_]+$" },
    "title": { "type": "string" },
    "output_text_license": { "type": "string" },
    "code_license": { "type": "string" },
    "model_backend": { "type": "string" },
    "default_model_profile": { "type": "string" },
    "local_model_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["model_profile_id", "adapter", "base_url", "model"],
        "additionalProperties": false,
        "properties": {
          "model_profile_id": { "type": "string" },
          "adapter": { "type": "string", "enum": ["llama.cpp", "ollama", "openai-compatible", "vllm"] },
          "base_url": { "type": "string" },
          "model": { "type": "string" },
          "api_key": { "type": "string" },
          "temperature": { "type": "number" },
          "max_tokens": { "type": "integer", "minimum": 1 },
          "timeout_seconds": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "allowed_sources": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "style_profiles": {
      "type": "array",
      "items": { "$ref": "style_profile.schema.json" }
    },
    "divine_name_policy": { "type": "string" },
    "review_policy": {
      "type": "object",
      "required": ["canonical_required_approvals", "alternate_required_approvals", "release_required_role"],
      "additionalProperties": false,
      "properties": {
        "canonical_required_approvals": { "type": "integer", "minimum": 1 },
        "alternate_required_approvals": { "type": "integer", "minimum": 1 },
        "release_required_role": { "type": "string" }
      }
    },
    "release_channel": { "type": "string" },
    "source_manifests": {
      "type": "array",
      "items": { "$ref": "source_manifest.schema.json" }
    }
  }
}
