{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HebrewToken",
  "type": "object",
  "required": [
    "token_id",
    "ref",
    "surface",
    "normalized",
    "transliteration",
    "lemma",
    "strong",
    "morph_code",
    "morph_readable",
    "part_of_speech",
    "syntax_role",
    "semantic_role",
    "referent",
    "word_sense",
    "occurrence_index",
    "corpus_occurrence_refs",
    "psalms_occurrence_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "token_id": { "type": "string", "pattern": "^ps\\d{3}\\.v\\d{3}\\.t\\d{3}$" },
    "ref": { "type": "string" },
    "surface": { "type": "string" },
    "normalized": { "type": "string" },
    "transliteration": { "type": "string" },
    "lemma": { "type": "string" },
    "strong": { "type": "string" },
    "morph_code": { "type": "string" },
    "morph_readable": { "type": "string" },
    "part_of_speech": { "type": "string" },
    "syntax_role": { "type": "string" },
    "semantic_role": { "type": "string" },
    "referent": { "type": "string" },
    "word_sense": { "type": "string" },
    "occurrence_index": { "type": "integer", "minimum": 1 },
    "corpus_occurrence_refs": { "type": "array", "items": { "type": "string" } },
    "psalms_occurrence_refs": { "type": "array", "items": { "type": "string" } }
  }
}
