      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA097.htm",
      "text": "Confounded be all they that serve graven images, that boast themselves of idols: worship him, all [ye] gods.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 97:7",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA097.htm",
      "text": "Let all them be put to shame that serve graven images, That boast themselves of idols: Worship him, all ye gods.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 97:7",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA097.htm",
