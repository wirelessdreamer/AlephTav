  "witnesses": [
    {
      "language": "en",
      "ref": "Psalm 139:16",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA139.htm",
      "text": "Thine eyes did see my substance, yet being unperfect; and in thy book all [my members] were written, [which] in continuance were fashioned, when [as yet there was] none of them.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 139:16",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA139.htm",
      "text": "Thine eyes did see mine unformed substance; And in thy book they were all written, [Even] the days that were ordained [for me], When as yet there was none of them.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 139:16",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA139.htm",
      "text": "Your eyes saw my body. In your book they were all written, the days that were ordained for me, when as yet there were none of them.",
      "versionTitle": "World English Bible"
    }
  ]
