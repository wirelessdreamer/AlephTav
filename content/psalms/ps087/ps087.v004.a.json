      "language": "en",
      "ref": "Psalm 87:4",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA087.htm",
      "text": "I will make mention of Rahab and Babylon to them that know me: behold Philistia, and Tyre, with Ethiopia; this [man] was born there.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 87:4",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA087.htm",
      "text": "I will make mention of Rahab and Babylon as among them that know me: Behold, Philistia, and Tyre, with Ethiopia: This one was born there.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 87:4",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA087.htm",
      "text": "I will record Rahab and Babylon among those who acknowledge me. Behold, Philistia, Tyre, and also Ethiopia: “This one was born there.”",
      "versionTitle": "World English Bible"
    }
