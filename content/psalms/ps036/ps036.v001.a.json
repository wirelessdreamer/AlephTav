      "language": "en",
      "ref": "Psalm 36:1",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA036.htm",
      "text": "To the chief Musician, [A Psalm] of David the servant of the LORD. The transgression of the wicked saith within my heart, [that there is] no fear of God before his eyes.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 36:1",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA036.htm",
      "text": "For the Chief Musician. [A Psalm] of David the servant of Jehovah. The transgression of the wicked saith within my heart, There is no fear of God before his eyes.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 36:1",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA036.htm",
      "text": "For the Chief Musician. By David, the servant of the LORD. A revelation is within my heart about the disobedience of the wicked: There is no fear of God before his eyes.",
      "versionTitle": "World English Bible"
    }
