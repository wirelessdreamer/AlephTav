      "language": "en",
      "ref": "Psalm 6:1",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA006.htm",
      "text": "To the chief Musician on Neginoth upon Sheminith, A Psalm of David. O LORD, rebuke me not in thine anger, neither chasten me in thy hot displeasure.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 6:1",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA006.htm",
      "text": "For the Chief Musician; on stringed instruments, set to the Sheminith. A Psalm of David. O Jehovah, rebuke me not in thine anger, Neither chasten me in thy hot displeasure.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 6:1",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA006.htm",
      "text": "For the Chief Musician; on stringed instruments, upon the eight-stringed lyre. A Psalm by David. LORD, don’t rebuke me in your anger, neither discipline me in your wrath.",
      "versionTitle": "World English Bible"
    }
  ]
