      "language": "en",
      "ref": "Psalm 58:1",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA058.htm",
      "text": "To the chief Musician, Al-taschith, Michtam of David. Do ye indeed speak righteousness, O congregation? do ye judge uprightly, O ye sons of men?",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 58:1",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA058.htm",
      "text": "For the Chief Musician; [set to] Al-tashheth. [A Psalm] of David. Michtam. Do ye indeed in silence speak righteousness? Do ye judge uprightly, O ye sons of men?",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 58:1",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA058.htm",
      "text": "For the Chief Musician. To the tune of “Do Not Destroy.” A poem by David. Do you indeed speak righteousness, silent ones? Do you judge blamelessly, you sons of men?",
      "versionTitle": "World English Bible"
    }
