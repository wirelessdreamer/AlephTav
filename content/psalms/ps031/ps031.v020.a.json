      "language": "en",
      "ref": "Psalm 31:20",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA031.htm",
      "text": "Thou shalt hide them in the secret of thy presence from the pride of man: thou shalt keep them secretly in a pavilion from the strife of tongues.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 31:20",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA031.htm",
      "text": "In the covert of thy presence wilt thou hide them from the plottings of man: Thou wilt keep them secretly in a pavilion from the strife of tongues.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 31:20",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA031.htm",
      "text": "In the shelter of your presence you will hide them from the plotting of man. You will keep them secretly in a dwelling away from the strife of tongues.",
