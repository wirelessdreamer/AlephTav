  "witnesses": [
    {
      "language": "en",
      "ref": "Psalm 31:11",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA031.htm",
      "text": "I was a reproach among all mine enemies, but especially among my neighbours, and a fear to mine acquaintance: they that did see me without fled from me.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 31:11",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA031.htm",
      "text": "Because of all mine adversaries I am become a reproach, Yea, unto my neighbors exceedingly, And a fear to mine acquaintance: They that did see me without fled from me.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 31:11",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA031.htm",
      "text": "Because of all my adversaries I have become utterly contemptible to my neighbors, a horror to my acquaintances. Those who saw me on the street fled from me.",
      "versionTitle": "World English Bible"
    }
  ]
