      "ref": "Psalm 31:10",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA031.htm",
      "text": "For my life is spent with grief, and my years with sighing: my strength faileth because of mine iniquity, and my bones are consumed.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 31:10",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA031.htm",
      "text": "For my life is spent with sorrow, And my years with sighing: My strength faileth because of mine iniquity, And my bones are wasted away.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 31:10",
