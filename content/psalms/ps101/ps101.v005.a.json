      "language": "en",
      "ref": "Psalm 101:5",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA101.htm",
      "text": "Whoso privily slandereth his neighbour, him will I cut off: him that hath an high look and a proud heart will not I suffer.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 101:5",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA101.htm",
      "text": "Whoso privily slandereth his neighbor, him will I destroy: Him that hath a high look and a proud heart will I not suffer.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 101:5",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA101.htm",
      "text": "I will silence whoever secretly slanders his neighbor. I won’t tolerate one who is arrogant and conceited.",
      "versionTitle": "World English Bible"
    }
  ]
