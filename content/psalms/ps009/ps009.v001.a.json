      "language": "en",
      "ref": "Psalm 9:1",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA009.htm",
      "text": "To the chief Musician upon Muthlabben, A Psalm of David. I will praise [thee], O LORD, with my whole heart; I will shew forth all thy marvellous works.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 9:1",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA009.htm",
      "text": "For the Chief Musician; set to Muth-labben. A Psalm of David. I will give thanks unto Jehovah with my whole heart; I will show forth all thy marvellous works.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 9:1",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA009.htm",
      "text": "For the Chief Musician. Set to “The Death of the Son.” A Psalm by David. I will give thanks to the LORD with my whole heart. I will tell of all your marvelous works.",
      "versionTitle": "World English Bible"
    }
