      "language": "en",
      "ref": "Psalm 10:5",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA010.htm",
      "text": "His ways are always grievous; thy judgments [are] far above out of his sight: [as for] all his enemies, he puffeth at them.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 10:5",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA010.htm",
      "text": "His ways are firm at all times; Thy judgments are far above out of his sight: As for all his adversaries, he puffeth at them.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 10:5",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA010.htm",
      "text": "His ways are prosperous at all times. He is arrogant, and your laws are far from his sight. As for all his adversaries, he sneers at them.",
      "versionTitle": "World English Bible"
    }
  ]
