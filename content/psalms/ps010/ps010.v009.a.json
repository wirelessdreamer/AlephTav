      "language": "en",
      "ref": "Psalm 10:9",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA010.htm",
      "text": "He lieth in wait secretly as a lion in his den: he lieth in wait to catch the poor: he doth catch the poor, when he draweth him into his net.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 10:9",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA010.htm",
      "text": "He lurketh in secret as a lion in his covert; He lieth in wait to catch the poor: He doth catch the poor, when he draweth him in his net.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 10:9",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA010.htm",
      "text": "He lurks in secret as a lion in his ambush. He lies in wait to catch the helpless. He catches the helpless when he draws him in his net.",
      "versionTitle": "World English Bible"
    }
