    },
    {
      "language": "en",
      "ref": "Psalm 55:3",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA055.htm",
      "text": "Because of the voice of the enemy, Because of the oppression of the wicked; For they cast iniquity upon me, And in anger they persecute me.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 55:3",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA055.htm",
