      "ref": "Psalm 79:8",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA079.htm",
      "text": "O remember not against us former iniquities: let thy tender mercies speedily prevent us: for we are brought very low.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 79:8",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA079.htm",
      "text": "Remember not against us the iniquities of our forefathers: Let thy tender mercies speedily meet us; For we are brought very low.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 79:8",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA079.htm",
      "text": "Don’t hold the iniquities of our forefathers against us. Let your tender mercies speedily meet us, for we are in desperate need.",
      "versionTitle": "World English Bible"
    }
  ]
