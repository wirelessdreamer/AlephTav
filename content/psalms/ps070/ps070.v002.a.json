  "witnesses": [
    {
      "language": "en",
      "ref": "Psalm 70:2",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA070.htm",
      "text": "Let them be ashamed and confounded that seek after my soul: let them be turned backward, and put to confusion, that desire my hurt.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 70:2",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA070.htm",
      "text": "Let them be put to shame and confounded That seek after my soul: Let them be turned backward and brought to dishonor That delight in my hurt.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 70:2",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA070.htm",
      "text": "Let them be disappointed and confounded who seek my soul. Let those who desire my ruin be turned back in disgrace.",
      "versionTitle": "World English Bible"
    }
  ]
