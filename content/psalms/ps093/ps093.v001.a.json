    {
      "language": "en",
      "ref": "Psalm 93:1",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA093.htm",
      "text": "The LORD reigneth, he is clothed with majesty; the LORD is clothed with strength, [wherewith] he hath girded himself: the world also is stablished, that it cannot be moved.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 93:1",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA093.htm",
      "text": "Jehovah reigneth; he is clothed with majesty; Jehovah is clothed with strength; he hath girded himself therewith: The world also is established, that it cannot be moved.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 93:1",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA093.htm",
      "text": "The LORD reigns! He is clothed with majesty! The LORD is armed with strength. The world also is established. It can’t be moved.",
      "versionTitle": "World English Bible"
    }
