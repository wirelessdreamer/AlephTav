  "witnesses": [
    {
      "language": "en",
      "ref": "Psalm 59:1",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA059.htm",
      "text": "To the chief Musician, Al-taschith, Michtam of David; when Saul sent, and they watched the house to kill him. Deliver me from mine enemies, O my God: defend me from them that rise up against me.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 59:1",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA059.htm",
      "text": "For the Chief Musician; [set to] Al-tashheth. [A Psalm] of David. Michtam; when Saul sent, and they watched the house to kill him. Deliver me from mine enemies, O my God: Set me on high from them that rise up against me.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 59:1",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA059.htm",
      "text": "For the Chief Musician. To the tune of “Do Not Destroy.” A poem by David, when Saul sent, and they watched the house to kill him. Deliver me from my enemies, my God. Set me on high from those who rise up against me.",
      "versionTitle": "World English Bible"
    }
  ]
