      "ref": "Psalm 89:39",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA089.htm",
      "text": "Thou hast abhorred the covenant of thy servant: Thou hast profaned his crown [by casting it] to the ground.",
      "versionTitle": "American Standard Version"
    },
