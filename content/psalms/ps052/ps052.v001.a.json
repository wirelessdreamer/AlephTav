  "witnesses": [
    {
      "language": "en",
      "ref": "Psalm 52:1",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA052.htm",
      "text": "To the chief Musician, Maschil, [A Psalm] of David, when Doeg the Edomite came and told Saul, and said unto him, David is come to the house of Ahimelech. Why boastest thou thyself in mischief, O mighty man? the goodness of God [endureth] continually.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 52:1",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA052.htm",
      "text": "For the Chief Musician. Maschil of David; when Doeg the Edomite came and told Saul, and said unto him, David is come to the house of Ahimelech. Why boastest thou thyself in mischief, O mighty man? The lovingkindness of God [endureth] continually.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 52:1",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA052.htm",
      "text": "For the Chief Musician. A contemplation by David, when Doeg the Edomite came and told Saul, “David has come to Ahimelech’s house.” Why do you boast of mischief, mighty man? God’s loving kindness endures continually.",
      "versionTitle": "World English Bible"
    }
  ]
