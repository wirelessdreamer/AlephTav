  "witnesses": [
    {
      "language": "en",
      "ref": "Psalm 15:4",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA015.htm",
      "text": "In whose eyes a vile person is contemned; but he honoureth them that fear the LORD. [He that] sweareth to [his own] hurt, and changeth not.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 15:4",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA015.htm",
      "text": "In whose eyes a reprobate is despised, But who honoreth them that fear Jehovah; He that sweareth to his own hurt, and changeth not;",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 15:4",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA015.htm",
      "text": "in whose eyes a vile man is despised, but who honors those who fear the LORD; he who keeps an oath even when it hurts, and doesn’t change;",
      "versionTitle": "World English Bible"
    }
