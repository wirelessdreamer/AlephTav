      "language": "en",
      "ref": "Psalm 88:9",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA088.htm",
      "text": "Mine eye mourneth by reason of affliction: LORD, I have called daily upon thee, I have stretched out my hands unto thee.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 88:9",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA088.htm",
      "text": "Mine eye wasteth away by reason of affliction: I have called daily upon thee, O Jehovah; I have spread forth my hands unto thee.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 88:9",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA088.htm",
      "text": "My eyes are dim from grief. I have called on you daily, LORD. I have spread out my hands to you.",
      "versionTitle": "World English Bible"
    }
