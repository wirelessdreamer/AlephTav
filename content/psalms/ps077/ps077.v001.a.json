      "ref": "Psalm 77:1",
      "source_id": "kjv",
      "source_url": "https://ebible.org/eng-kjv2006/PSA077.htm",
      "text": "To the chief Musician, to Jeduthun, A Psalm of Asaph. I cried unto God with my voice, [even] unto God with my voice; and he gave ear unto me.",
      "versionTitle": "King James Version"
    },
    {
      "language": "en",
      "ref": "Psalm 77:1",
      "source_id": "asv",
      "source_url": "https://ebible.org/eng-asv/PSA077.htm",
      "text": "For the Chief Musician; after the manner of Jeduthun. A Psalm of Asaph. I will cry unto God with my voice, Even unto God with my voice; and he will give ear unto me.",
      "versionTitle": "American Standard Version"
    },
    {
      "language": "en",
      "ref": "Psalm 77:1",
      "source_id": "web",
      "source_url": "https://ebible.org/engwebp/PSA077.htm",
      "text": "For the Chief Musician. To Jeduthun. A Psalm by Asaph. My cry goes to God! Indeed, I cry to God for help, and for him to listen to me.",
      "versionTitle": "World English Bible"
    }
