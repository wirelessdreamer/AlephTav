{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenerationInput",
  "type": "object",
  "required": ["unit_id", "layer", "locked_inputs", "style_profile", "candidate_count", "seed", "model_profile_id"],
  "additionalProperties": false,
  "properties": {
    "unit_id": { "type": "string" },
    "layer": { "type": "string" },
    "locked_inputs": { "type": "object" },
    "style_profile": { "type": "object" },
    "candidate_count": { "type": "integer", "minimum": 1 },
    "seed": { "type": "integer" },
    "model_profile_id": { "type": "string" }
  }
}
