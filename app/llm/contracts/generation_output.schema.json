{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenerationOutput",
  "type": "object",
  "required": ["unit_id", "layer", "candidates"],
  "additionalProperties": false,
  "properties": {
    "unit_id": { "type": "string" },
    "layer": { "type": "string" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "rationale", "alignment_hints", "drift_flags", "metrics"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string" },
          "rationale": { "type": "string" },
          "alignment_hints": { "type": "array" },
          "drift_flags": {
            "type": "array",
            "items": {
              "anyOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["code", "severity", "confidence", "message"],
                  "additionalProperties": false,
                  "properties": {
                    "code": { "type": "string" },
                    "severity": { "type": "string", "enum": ["low", "medium", "high"] },
                    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                    "message": { "type": "string" }
                  }
                }
              ]
            }
          },
          "metrics": { "type": "object" }
        }
      }
    }
  }
}
